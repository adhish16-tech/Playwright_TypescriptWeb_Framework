# Copy this file to .env.dev / .env.staging / .env.prod and fill in values
# Never commit real credentials — use CI secrets in pipelines

ENV=dev
BASE_URL=https://your-app-url.com
API_URL=https://your-api-url.com

# Test credentials
TEST_USERNAME=your-test-username
TEST_PASSWORD=your-test-password

# Logging
LOG_LEVEL=debug

# Timeouts (ms)
DEFAULT_TIMEOUT=60000
ACTION_TIMEOUT=15000
