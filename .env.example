# Copy this file to .env.dev / .env.qa and fill in values
# Never commit real credentials — use CI secrets in pipelines

# ENV options: dev | qa
ENV=dev
BASE_URL=https://webdev.fleetforc.com
API_URL=https://webdev.fleetforc.com/api

# Test credentials
TEST_USERNAME=your-test-username
TEST_PASSWORD=your-test-password

# Logging
LOG_LEVEL=debug

# Timeouts (ms)
DEFAULT_TIMEOUT=60000
ACTION_TIMEOUT=15000
